{
  "expo": {
    "name": "Himoinsa Workshop Mobile App",
    "slug": "himoinsa-workshop-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "himoinsaworkshopmobileapp",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#0c0c6e",
    "description": "Himoinsa technician mobile app for job card execution.",
    "privacy": "unlisted",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/himoinsa-splash-screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.himoinsa.mobileapp",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.himoinsa.mobileapp",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to capture job card photos and signatures."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to track your location for technician travel and job card GPS tagging."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/himoinsa-splash-screen.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "a302073f-1c1c-4367-802e-9647f20b7960"
      }
    }
  }
}
